# ========== Dashboard (mot de passe pour accéder à l’UI et aux fonctions de lecture) ==========
# Même valeur que demandée côté équipe — à définir aussi sur Netlify (ne pas commiter .env)
DASHBOARD_PASSWORD=
# Optionnel : secret dédié pour signer la session cookie (sinon dérivé du mot de passe)
# DASHBOARD_AUTH_SECRET=
# Debug : logs serveur [dashboard-auth …] + GET /.netlify/functions/dashboard-debug (JSON)
# DASHBOARD_DEBUG=1
# Logs Shopify (événement JSON shopify_auth_debug : boutique, mode auth, préfixes token/client id)
# SHOPIFY_DEBUG=1

# ========== Shopify PRODUCTION ==========
PROD_SHOPIFY_STORE_DOMAIN=xxxx.myshopify.com
PROD_SHOPIFY_CLIENT_ID=xxxx
PROD_SHOPIFY_CLIENT_SECRET=xxxx
# Mode auto Dev Dashboard : laisser VIDE si vous n’utilisez que CLIENT_ID + CLIENT_SECRET
# (app installée sur PROD_SHOPIFY_STORE_DOMAIN). Sinon, coller un Admin API access token statique.
PROD_SHOPIFY_ADMIN_ACCESS_TOKEN=
PROD_SHOPIFY_UK_LOCATION_ID=123456789

# ========== Shopify STAGING (boutique / app dédiés) ==========
STAGING_SHOPIFY_STORE_DOMAIN=staging-shop-aperol.myshopify.com
STAGING_SHOPIFY_CLIENT_ID=
STAGING_SHOPIFY_CLIENT_SECRET=
# Laisser vide pour mode auto (CLIENT_ID + CLIENT_SECRET + app installée sur ce shop), comme en prod.
STAGING_SHOPIFY_ADMIN_ACCESS_TOKEN=
STAGING_SHOPIFY_UK_LOCATION_ID=

# ========== Byrd (WMS) — partagé prod + staging sauf override STAGING_BYRD_* ==========
# Ne pas mettre d’exemple de clé tokenée ici (scan Netlify / sécurité). Coller les vraies valeurs dans .env local ou Netlify UI.
BYRD_API_KEY=
BYRD_API_SECRET=
BYRD_WAREHOUSE_ID=
# Vide = URL par défaut côté code (GetByrd production). Sinon définir dans .env / Netlify uniquement.
BYRD_BASE_URL=

# ========== Slack (optionnel) — même webhook pour prod et staging ==========
# Incoming Webhook Slack (résumé de chaque run + alertes)
SLACK_WEBHOOK_URL=
# 0|false|off : désactive TOUS les envois Slack (digest + après chaque sync). Défaut : activé si absent
# SLACK_NOTIFICATIONS=1
# 0 : pas de Slack après chaque sync-uk / sync stock ; le digest quotidien reste possible si activé ailleurs
# SLACK_PER_RUN_REPORTS=1
# Rapport quotidien « hier » (cron + daily-slack-digest-manual) — 0 pour désactiver seulement le digest
# SLACK_DAILY_DIGEST=1
# Fuseau pour la journée « veille » (ex. Europe/Paris)
# SLACK_DAILY_DIGEST_TIMEZONE=Europe/Paris
# Titre affiché dans le message (optionnel)
# SLACK_DAILY_DIGEST_SITE_LABEL=Aperol UK
# Secret pour appeler /.netlify/functions/daily-slack-digest-manual (Authorization: Bearer … ou X-Daily-Digest-Secret)
# DAILY_DIGEST_HTTP_SECRET=
# (Optionnel) Fichier des surcharges Slack définies dans le dashboard ; sinon data/slack-settings.json hors Netlify
# SLACK_SETTINGS_PATH=./data/slack-settings.json

# ========== Logs fichier (optionnel) ==========
# Chemin d'un fichier log JSONL (sera cree si necessaire). Utile en local.
LOG_FILE_PATH=./middleware.log

# ========== Sync / historique ==========
# (Optionnel) Fichier JSON pour l’historique « Runs sync » en local ; sinon data/sync-runs.json hors Netlify
# SYNC_RUN_HISTORY_PATH=./data/sync-runs.json

# Scripts Shopify : SHOPIFY_TARGET=staging pour cibler le staging (défaut prod)
# SHOPIFY_TARGET=prod
